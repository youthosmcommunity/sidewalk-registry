{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sidewalk Registry sources.json",
  "type": "object",
  "required": ["generated_at", "source", "provinces", "municipalities"],
  "properties": {
    "generated_at": { "type": "string" },
    "source": {
      "type": "object",
      "required": ["name", "catalogue", "license", "collected"],
      "properties": {
        "name": { "type": "string" },
        "catalogue": { "type": "string" },
        "license": { "type": "string" },
        "collected": { "type": "string" }
      }
    },
    "provinces": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["name", "covered", "municipality_count"],
        "properties": {
          "name": { "type": "string" },
          "covered": { "type": "boolean" },
          "municipality_count": { "type": "integer" },
          "gap_narrative": { "type": "string" }
        }
      }
    },
    "municipalities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "province_code",
          "municipality_slug",
          "municipality_name",
          "feature_count",
          "category_counts",
          "pct_has_width",
          "pct_has_surface",
          "bbox",
          "sources"
        ],
        "properties": {
          "province_code": { "type": "string" },
          "municipality_slug": { "type": "string" },
          "municipality_name": { "type": "string" },
          "csd_uid": { "type": "string" },
          "feature_count": { "type": "integer" },
          "category_counts": { "type": "object" },
          "pct_has_width": { "type": "number" },
          "pct_has_surface": { "type": "number" },
          "bbox": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 4,
            "maxItems": 4
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "file_name": { "type": "string" },
                "source_url": { "type": "string" },
                "licence_url": { "type": "string" },
                "attribution_statement": { "type": "string" },
                "last_update": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
